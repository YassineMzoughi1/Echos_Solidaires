# --- SMTP (Gmail App Password) -------------------------------------------
# In your Google Account → Security → "App passwords", generate a 16-char
# password (you need 2FA enabled). Use it below as SMTP_PASS — NOT your
# normal Gmail password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"

# Header shown to recipients (use a display name + the Gmail you authenticated with)
SMTP_FROM="Échos Solidaires <your-gmail@gmail.com>"

# Inbox that receives every form submission
NOTIFY_EMAIL="destination@example.com"
