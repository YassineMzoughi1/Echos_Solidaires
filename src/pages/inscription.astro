---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const paymentOptions = [
  { value: 'cb',       label: 'Carte bancaire' },
  { value: 'd17',      label: 'D17 / Mobile money' },
  { value: 'virement', label: 'Virement bancaire' },
  { value: 'place',    label: 'Paiement sur place' }
];

const fieldBase =
  'w-full h-12 md:h-13 px-5 bg-transparent border-2 border-indigo rounded-md font-sans text-body text-ink-700 placeholder:text-ink-500 transition-colors duration-300 ease-editorial focus-visible:border-[#C96C4B] focus:outline-none';
---

<BaseLayout title="Inscription — Échos Solidaires">
  <Nav />

  <main
    id="contenu"
    class="min-h-[100svh] flex flex-col bg-cream"
    transition:animate="fade"
  >
    <section class="flex-1 flex items-center justify-center px-6 md:px-12 lg:px-20 pt-24 md:pt-28 pb-8 md:pb-10">
      <div class="w-full max-w-5xl mx-auto" data-inscription-shell>

        <h1
          class="text-center font-sans font-bold leading-[1.05] mb-8 md:mb-10"
          style="font-size: clamp(40px, 6vw, 72px); color: #C96C4B;"
          data-inscription-title
        >
          Formulaire
        </h1>

        <div class="relative">
          <form
            data-form
            data-form-wrap
            novalidate
            class="grid grid-cols-1 md:grid-cols-2 gap-x-8 lg:gap-x-12 gap-y-4 md:gap-y-5"
            aria-describedby="form-help"
          >
            <div>
              <label for="f-nom" class="sr-only">Nom</label>
              <input id="f-nom" name="nom" type="text" placeholder="Nom"
                autocomplete="family-name" required class={fieldBase} />
            </div>

            <div>
              <label for="f-prenom" class="sr-only">Prénom</label>
              <input id="f-prenom" name="prenom" type="text" placeholder="Prénom"
                autocomplete="given-name" required class={fieldBase} />
            </div>

            <div>
              <label for="f-email" class="sr-only">Email</label>
              <input id="f-email" name="email" type="email" placeholder="Email"
                autocomplete="email" required class={fieldBase} />
            </div>

            <div>
              <label for="f-tel" class="sr-only">Numéro de téléphone</label>
              <input id="f-tel" name="telephone" type="tel" placeholder="Num Tel"
                autocomplete="tel" required class={fieldBase} />
            </div>

            <div class="relative">
              <label for="f-password" class="sr-only">Mot de passe</label>
              <input id="f-password" name="password" type="password"
                placeholder="Mot de Passe" autocomplete="new-password" required
                class={fieldBase + ' pr-14'} data-password-input />
              <button
                type="button"
                data-password-toggle
                aria-label="Afficher le mot de passe"
                aria-pressed="false"
                class="absolute right-4 top-1/2 -translate-y-1/2 inline-flex items-center justify-center w-9 h-9 text-indigo hover:text-[#C96C4B] transition-colors"
              >
                <i class="ph ph-eye-slash text-[20px]" data-password-icon></i>
              </button>
            </div>

            <div>
              <label for="f-adresse" class="sr-only">Adresse</label>
              <input id="f-adresse" name="adresse" type="text" placeholder="Adresse"
                autocomplete="street-address" class={fieldBase} />
            </div>

            <div>
              <label for="f-participants" class="sr-only">Nombre de participants</label>
              <input id="f-participants" name="participants" type="number" min="1"
                placeholder="Nombre de participants" class={fieldBase} />
            </div>

            <div class="relative">
              <label for="f-paiement" class="sr-only">Mode de paiement</label>
              <select id="f-paiement" name="paiement" required
                class={fieldBase + ' appearance-none pr-12 text-ink-500'}
                data-select
              >
                <option value="" disabled selected>Mode de paiement</option>
                {paymentOptions.map((o) => (
                  <option value={o.value} class="text-ink-700">{o.label}</option>
                ))}
              </select>
              <i class="ph ph-caret-down absolute right-4 top-1/2 -translate-y-1/2 text-indigo pointer-events-none text-[18px]"></i>
            </div>

            <div class="md:col-span-2 flex flex-col items-center gap-3 mt-4 md:mt-6">
              <button
                data-submit-btn
                type="submit"
                class="relative inline-flex items-center justify-center bg-indigo text-cream hover:opacity-90 font-sans font-bold text-body uppercase tracking-[0.18em] btn-arc h-14 px-20 md:px-28 overflow-hidden transition-all duration-300 ease-editorial disabled:cursor-not-allowed"
              >
                <span data-btn-label class="inline-flex items-center justify-center gap-3 transition-opacity duration-300">
                  Inscription
                </span>
                <span data-btn-loading class="absolute inset-0 inline-flex items-center justify-center gap-3 opacity-0 pointer-events-none transition-opacity duration-300">
                  <span class="inscription-spinner" aria-hidden="true"></span>
                  <span>Envoi en cours</span>
                </span>
              </button>
              <p id="form-help" class="text-body-sm text-ink-500 text-center max-w-[52ch]">
                Vos données restent confidentielles et ne sont utilisées que pour
                l’organisation de l’événement.
              </p>
            </div>
          </form>

          <!-- Success state — swapped in by initForms() after submit -->
          <div
            data-form-success
            class="flex-col items-center text-center gap-5 bg-sable rounded-lg border border-ink-300/50 px-8 py-12 md:py-14"
            style="display: none;"
          >
            <span class="inline-flex items-center justify-center w-12 h-12 rounded-full border border-oasis text-oasis" aria-hidden="true">
              <i class="ph ph-check text-[22px]"></i>
            </span>
            <h2
              class="font-sans font-bold text-forest leading-[1.15]"
              style="font-size: clamp(24px, 3vw, 32px);"
            >
              Merci. Votre inscription a été reçue.
            </h2>
            <p class="text-body text-ink-700 max-w-[48ch]">
              Un message de confirmation vous parviendra prochainement à
              l’adresse que vous avez renseignée.
            </p>
            <a
              href="/"
              class="mt-2 inline-flex items-center justify-center gap-2 bg-[#C96C4B] text-cream hover:opacity-90 font-sans font-semibold text-body-sm uppercase tracking-[0.15em] btn-arc h-12 px-8 transition-all duration-300 ease-editorial"
            >
              <i class="ph ph-arrow-left text-[16px]"></i>
              Retour à l’accueil
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <style>
    /* Submit button loading state */
    .inscription-spinner {
      width: 18px;
      height: 18px;
      border-radius: 9999px;
      border: 2px solid rgba(249, 241, 228, 0.35);
      border-top-color: #F9F1E4;
      animation: inscription-spin 0.7s linear infinite;
    }
    @keyframes inscription-spin { to { transform: rotate(360deg); } }
    [data-submit-btn].is-loading [data-btn-label]   { opacity: 0; }
    [data-submit-btn].is-loading [data-btn-loading] { opacity: 1; }
  </style>

  <script>
    import { gsap } from 'gsap';

    const reducedMotion = () =>
      window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Per-page wiring — re-runs on every view transition.
    function wireInscriptionPage() {
      const shell = document.querySelector<HTMLElement>('[data-inscription-shell]');
      if (!shell) return;

      // Entrance animation: title + form drift up & fade in.
      const title = shell.querySelector<HTMLElement>('[data-inscription-title]');
      const form = shell.querySelector<HTMLElement>('[data-form-wrap]');
      if (!reducedMotion() && title && form) {
        gsap.set([title, form], { opacity: 0, y: 24 });
        gsap.to(title, { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' });
        gsap.to(form,  { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out', delay: 0.12 });
      }

      // Password visibility toggle
      const toggle = shell.querySelector<HTMLButtonElement>('[data-password-toggle]');
      const input  = shell.querySelector<HTMLInputElement>('[data-password-input]');
      const icon   = shell.querySelector<HTMLElement>('[data-password-icon]');
      if (toggle && input && icon && !toggle.dataset.wired) {
        toggle.dataset.wired = '1';
        toggle.addEventListener('click', () => {
          const hidden = input.type === 'password';
          input.type = hidden ? 'text' : 'password';
          toggle.setAttribute('aria-pressed', String(hidden));
          toggle.setAttribute(
            'aria-label',
            hidden ? 'Masquer le mot de passe' : 'Afficher le mot de passe'
          );
          icon.className = hidden ? 'ph ph-eye text-[20px]' : 'ph ph-eye-slash text-[20px]';
        });
      }

      // Keep the select placeholder grey until a real value is chosen
      const select = shell.querySelector<HTMLSelectElement>('[data-select]');
      if (select) {
        const sync = () => {
          if (select.value === '') {
            select.classList.add('text-ink-500');
            select.classList.remove('text-ink-700');
          } else {
            select.classList.remove('text-ink-500');
            select.classList.add('text-ink-700');
          }
        };
        sync();
        if (!select.dataset.wired) {
          select.dataset.wired = '1';
          select.addEventListener('change', sync);
        }
      }
    }

    document.addEventListener('astro:page-load', wireInscriptionPage);
  </script>
</BaseLayout>
