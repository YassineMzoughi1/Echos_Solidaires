---
import '@fontsource-variable/inter/index.css';
import '@fontsource-variable/cormorant-garamond/index.css';
import '@phosphor-icons/web/regular';
import '../styles/global.css';
import fs from 'node:fs';
import path from 'node:path';
import { eventMeta } from '../lib/data';

const publicDir = path.join(process.cwd(), 'public');
const heroPoster = fs.existsSync(path.join(publicDir, 'images', 'hero-poster.jpg'))
  ? '/images/hero-poster.jpg'
  : '/images/hero-poster.svg';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = `${eventMeta.title} — ${eventMeta.date}, ${eventMeta.location.split(',')[0]}`,
  description = eventMeta.description,
  ogImage = '/og.png'
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;

const eventJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: eventMeta.title,
  startDate: eventMeta.startDate,
  endDate: eventMeta.endDate,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: {
    '@type': 'Place',
    name: 'Nefta',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Nefta',
      addressRegion: 'Tozeur',
      addressCountry: 'TN'
    }
  },
  organizer: {
    '@type': 'Organization',
    name: 'Échos Solidaires',
    url: canonical
  },
  description
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#F9F1E4" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonical} />
    <link rel="preload" as="image" href={heroPoster} fetchpriority="high" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(eventJsonLd)} />
  </head>
  <body class="bg-cream text-ink-700 antialiased">
    <a class="skip-link" href="#a-propos">Aller au contenu</a>
    <slot />

    <script>
      import { initLenis } from '../lib/lenis';
      import {
        initReveals,
        initWordReveals,
        initCountUps,
        initNav,
        initMobileMenu,
        initProgrammeTabs,
        initInitiativesScroll,
        initGalleryFilter,
        initForms,
        initAboutParallax,
        heroIntro
      } from '../lib/animations';

      const boot = () => {
        initLenis();
        initNav();
        initMobileMenu();
        const hero = document.querySelector<HTMLElement>('[data-hero]');
        if (hero) heroIntro(hero);
        initReveals();
        initWordReveals();
        initCountUps();
        initProgrammeTabs();
        initInitiativesScroll();
        initGalleryFilter();
        initForms();
        initAboutParallax();
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', boot, { once: true });
      } else {
        boot();
      }
    </script>
  </body>
</html>
