---
import Input from './ui/Input.astro';

const paymentOptions = [
  { value: 'cb',       label: 'Carte bancaire' },
  { value: 'd17',      label: 'D17 / Mobile money' },
  { value: 'virement', label: 'Virement bancaire' },
  { value: 'place',    label: 'Paiement sur place' }
];
---

<section id="formulaire" class="bg-cream">
  <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20 py-16 md:py-20 lg:py-32">
    <header class="flex flex-col gap-5 max-w-3xl">
      <p class="text-eyebrow font-medium uppercase tracking-[0.2em] text-argile" data-reveal>
        Inscription
      </p>
      <h2
        class="font-sans font-semibold text-[#3F6B52] leading-[1.1]"
        style="font-size: clamp(36px, 5.5vw, 56px);"
        data-reveal
      >
        Formulaire
      </h2>
      <p class="text-body-lg text-ink-700 max-w-[58ch]" data-reveal>
        Réservez votre place pour les deux journées à Nefta. Nous reviendrons
        vers vous sous 48 h avec la confirmation et les modalités d’accueil.
      </p>
    </header>

    <div class="relative mt-12 md:mt-16">
      <form
        data-form
        novalidate
        class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6"
        aria-describedby="form-help"
      >
        <Input id="f-nom"        name="nom"               label="Nom"                    autocomplete="family-name"  required />
        <Input id="f-prenom"     name="prenom"            label="Prénom"                 autocomplete="given-name"   required />
        <Input id="f-email"      name="email"             label="Email"           type="email"   autocomplete="email"        required />
        <Input id="f-tel"        name="telephone"         label="Numéro de téléphone" type="tel"   autocomplete="tel"          required />
        <Input id="f-password"   name="password"          label="Mot de passe"    type="password"  autocomplete="new-password" required />
        <Input id="f-adresse"    name="adresse"           label="Adresse"                autocomplete="street-address" />
        <Input id="f-participants" name="participants"    label="Nombre de participants" type="number" />
        <Input id="f-paiement"   name="paiement"          label="Moyen de paiement"      as="select" options={paymentOptions} required />

        <div class="md:col-span-2 mt-2">
          <button
            type="submit"
            class="group inline-flex w-full items-center justify-center gap-3 bg-[#C96C4B] text-cream hover:opacity-90 font-sans font-semibold text-body-sm uppercase tracking-[0.15em] btn-arc h-14 transition-all duration-300 ease-editorial"
          >
            S’inscrire
            <span class="inline-flex transition-transform duration-400 ease-editorial group-hover:translate-x-1">
              <i class="ph ph-arrow-right text-[18px]"></i>
            </span>
          </button>
          <p id="form-help" class="mt-3 text-body-sm text-ink-500">
            Vos données restent confidentielles et ne sont utilisées que pour
            l’organisation de l’événement.
          </p>
        </div>
      </form>

      <!-- Success card (revealed after submit by initForms) -->
      <div
        data-form-success
        hidden
        class="bg-sable rounded-lg border border-ink-300/50 px-8 py-12 md:py-16 text-center flex flex-col items-center gap-5"
      >
        <span class="inline-flex items-center justify-center w-12 h-12 rounded-full border border-oasis text-oasis" aria-hidden="true">
          <i class="ph ph-check text-[22px]"></i>
        </span>
        <h3
          class="font-sans font-bold text-[#3F6B52] leading-[1.15]"
          style="font-size: clamp(28px, 4vw, 40px);"
        >
          Merci. Votre inscription a été reçue.
        </h3>
        <p class="text-body text-ink-700 max-w-[48ch]">
          Un message de confirmation vous parviendra prochainement à l’adresse
          que vous avez renseignée.
        </p>
      </div>
    </div>
  </div>
</section>
