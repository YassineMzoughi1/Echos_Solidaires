---
import Button from './ui/Button.astro';
---

<section class="bg-[#1E293B]">
  <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20 py-24 md:py-32 lg:py-40">
    <div class="flex flex-col items-center gap-8 text-center max-w-3xl mx-auto">
      <h2
        class="font-display font-bold text-white leading-[1.1]"
        style="font-size: clamp(40px, 6vw, 64px);"
        data-reveal
      >
        Rejoignez notre événement
      </h2>

      <div
        class="text-body-lg text-white max-w-[60ch] flex flex-col gap-4"
        data-word-reveal
      >
        <p>
          Chercheurs, artisans, associations, habitants et porteurs d’initiatives se réunissent à Nefta<br class="hidden md:block"/>
          pour partager savoirs, expériences et solutions locales.
        </p>
        <p>
          Boutons :
        </p>
      </div>

      <div data-reveal class="mt-2 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#contact"
          class="inline-flex items-center justify-center w-full sm:w-[180px] bg-transparent text-white border-2 border-white hover:bg-white/10 font-sans font-semibold text-body-sm tracking-[0.02em] btn-arc h-14 transition-all duration-300 ease-editorial"
        >
          Contact
        </a>
        <a
          href="#formulaire"
          class="inline-flex items-center justify-center w-full sm:w-[180px] bg-[#C96C4B] text-white border-2 border-white hover:opacity-90 font-sans font-semibold text-body-sm tracking-[0.02em] btn-arc h-14 transition-all duration-300 ease-editorial"
        >
          Participer
        </a>
      </div>
    </div>
  </div>
</section>
