---
import Button from './ui/Button.astro';
---

<section class="bg-[#C4C4C4]">
  <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20 py-24 md:py-32 lg:py-40">
    <div class="flex flex-col items-center gap-8 text-center max-w-3xl mx-auto">
      <h2
        class="font-display font-medium text-indigo leading-[1.1]"
        style="font-size: clamp(40px, 6vw, 64px);"
        data-reveal
      >
        Rejoignez notre <em class="not-italic font-display italic">événement</em>
      </h2>

      <p
        class="text-body-lg text-indigo/80 max-w-[60ch]"
        data-word-reveal
      >
        Chercheurs, artisans, associations, habitants et porteurs d’initiatives
        se réunissent à Nefta pour partager savoirs, expériences et solutions
        locales.
      </p>

      <div data-reveal class="mt-2 flex flex-col sm:flex-row items-center gap-4">
        <Button href="#formulaire" variant="primary" arrow>Participer</Button>
        <Button href="#contact" variant="ghost">Contact</Button>
      </div>
    </div>
  </div>
</section>
