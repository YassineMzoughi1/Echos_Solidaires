---
interface Props {
  id: string;
  name: string;
  label: string;
  type?: string;
  placeholder?: string;
  required?: boolean;
  as?: 'input' | 'select' | 'textarea';
  options?: Array<{ value: string; label: string }>;
  rows?: number;
  autocomplete?: string;
}

const {
  id,
  name,
  label,
  type = 'text',
  placeholder,
  required = false,
  as = 'input',
  options = [],
  rows = 5,
  autocomplete
} = Astro.props;

const fieldBase =
  'w-full h-12 px-4 bg-cream border border-ink-300 rounded-md text-body text-ink-700 placeholder:text-ink-500 transition-colors duration-300 ease-editorial focus-visible:border-indigo';
---

<div class="flex flex-col gap-2">
  <label
    for={id}
    class="text-caption font-medium uppercase tracking-[0.15em] text-indigo"
  >
    {label}
  </label>

  {as === 'input' && (
    <input
      id={id}
      name={name}
      type={type}
      placeholder={placeholder}
      required={required}
      autocomplete={autocomplete}
      class={fieldBase}
    />
  )}

  {as === 'select' && (
    <div class="relative">
      <select
        id={id}
        name={name}
        required={required}
        class={fieldBase + ' appearance-none pr-12'}
      >
        <option value="" disabled selected>Choisir…</option>
        {options.map((o: { value: string; label: string }) => <option value={o.value}>{o.label}</option>)}
      </select>
      <i class="ph ph-caret-down absolute right-4 top-1/2 -translate-y-1/2 text-indigo pointer-events-none text-[18px]"></i>
    </div>
  )}

  {as === 'textarea' && (
    <textarea
      id={id}
      name={name}
      placeholder={placeholder}
      required={required}
      rows={rows}
      class={fieldBase + ' h-auto py-3 leading-relaxed resize-vertical'}
    ></textarea>
  )}
</div>
