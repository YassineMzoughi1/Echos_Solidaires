---
/**
 * Renders <img> if the asset exists in /public; otherwise renders a SVG
 * placeholder using the brand palette so missing assets never break layout.
 * Designed for non-critical decorative images (programme thumbs, gallery, etc.).
 */
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  src: string;          // e.g. "/images/gallery-01.jpg"
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'eager' | 'lazy';
  decoding?: 'sync' | 'async' | 'auto';
  fallbackLabel?: string;
}

const {
  src,
  alt,
  width,
  height,
  class: cls = '',
  loading = 'lazy',
  decoding = 'async',
  fallbackLabel
} = Astro.props;

// Look up in /public (synchronous at build time only — fine for SSG)
const publicPath = path.join(process.cwd(), 'public', src.replace(/^\//, ''));
let exists = false;
try {
  exists = fs.existsSync(publicPath);
} catch (_e) {
  exists = false;
}

// Picks a tint that varies across placeholders
function hashCol(str: string) {
  let h = 0;
  for (let i = 0; i < str.length; i++) h = (h * 31 + str.charCodeAt(i)) >>> 0;
  const palette = ['#E8DBB7', '#1A2639', '#99C78C', '#DDA13E', '#C84B31'];
  return palette[h % palette.length];
}
const tint = hashCol(src);
const w = width ?? 1200;
const h = height ?? 800;
const initials = (fallbackLabel ?? alt)
  .replace(/[^\p{L}\s]/gu, '')
  .split(/\s+/)
  .slice(0, 2)
  .map((s) => s[0]?.toUpperCase() ?? '')
  .join('');
---

{exists ? (
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding={decoding}
    class={cls}
  />
) : (
  <svg
    role="img"
    aria-label={alt}
    viewBox={`0 0 ${w} ${h}`}
    width={width}
    height={height}
    class={cls}
    preserveAspectRatio="xMidYMid slice"
  >
    <defs>
      <linearGradient id={`g-${tint.slice(1)}-${w}-${h}`} x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color={tint} />
        <stop offset="100%" stop-color="#1A2639" />
      </linearGradient>
      <pattern id={`p-${w}-${h}`} width="60" height="60" patternUnits="userSpaceOnUse">
        <path d="M0 60L60 0" stroke="#F9F1E4" stroke-opacity="0.08" stroke-width="1" />
      </pattern>
    </defs>
    <rect width={w} height={h} fill={`url(#g-${tint.slice(1)}-${w}-${h})`} />
    <rect width={w} height={h} fill={`url(#p-${w}-${h})`} />
    <text
      x="50%"
      y="50%"
      dominant-baseline="middle"
      text-anchor="middle"
      fill="#F9F1E4"
      font-family="'Cormorant Garamond Variable', Georgia, serif"
      font-size={Math.min(w, h) * 0.22}
      font-weight="500"
      opacity="0.92"
    >
      {initials || 'É'}
    </text>
  </svg>
)}
