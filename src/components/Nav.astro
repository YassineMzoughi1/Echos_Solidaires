---
import { navLinks } from '../lib/data';

const pathname = Astro.url.pathname.replace(/\/$/, '');
const isHome = pathname === '' || pathname === '/index.html';
const logoHref = isHome ? '#accueil' : '/';

// On non-home pages, prefix anchor links with "/" so the browser navigates
// back to the index page (where the sections live) before scrolling.
const resolvedNavLinks = navLinks.map((l) => ({
  ...l,
  href: isHome ? l.href : `/${l.href}`
}));
---

<header
  data-nav
  class:list={[
    'fixed inset-x-0 top-0 z-50 transition-all duration-300 ease-editorial',
    isHome ? 'is-home' : 'backdrop-blur-xl bg-cream/80'
  ]}
>
  <div
    class="max-w-content mx-auto flex items-center justify-between px-6 md:px-12 lg:px-20 h-20"
  >
    <a href={logoHref} data-logo class="logo-wordmark text-indigo block" aria-label="Échos Solidaires — accueil">
      <img src="/images/logo.png" alt="Échos Solidaires" width="256" height="256" style="height: 44px; width: auto; display: block;" />
    </a>

    <nav class="hidden lg:flex items-center gap-10" aria-label="Navigation principale">
      {resolvedNavLinks.map((l) => (
        <a
          href={l.href}
          class="nav-link text-ink-700 hover:text-indigo text-body-sm font-medium"
        >
          {l.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-4">
      <a
        href="/inscription"
        class="hidden md:inline-flex items-center justify-center bg-[#3F6B52] text-cream hover:opacity-90 font-semibold text-body-sm uppercase tracking-[0.15em] btn-arc h-11 px-6 transition-all duration-300 ease-editorial"
      >
        Participer
      </a>

      <button
        type="button"
        data-menu-toggle
        aria-label="Ouvrir le menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
        class="lg:hidden inline-flex items-center justify-center w-11 h-11 rounded-md border border-indigo/20 text-indigo"
      >
        <i class="ph ph-list text-[22px]"></i>
      </button>
    </div>
  </div>

  <div data-nav-border class="rule opacity-0 transition-opacity duration-300 ease-editorial"></div>
</header>

<!-- Mobile full-screen menu -->
<aside
  id="mobile-menu"
  data-mobile-menu
  data-open="false"
  class="lg:hidden fixed inset-0 z-40 bg-cream pointer-events-none opacity-0 transition-opacity duration-400 ease-editorial"
  aria-hidden="true"
>
  <div class="h-full flex flex-col px-6 pt-28 pb-12">
    <nav class="flex-1 flex flex-col gap-6" aria-label="Menu mobile">
      {resolvedNavLinks.map((l) => (
        <a
          data-menu-item
          href={l.href}
          class="font-sans font-bold text-[40px] leading-none text-[#3F6B52]"
        >
          {l.label}
        </a>
      ))}
    </nav>
    <a
      data-menu-item
      href="/inscription"
      class="inline-flex items-center justify-center bg-[#3F6B52] text-cream hover:opacity-90 font-semibold text-body-sm uppercase tracking-[0.15em] btn-arc h-14 w-full transition-all duration-300 ease-editorial"
    >
      Participer
    </a>
  </div>
</aside>

<style>
  /* Home page: nav starts transparent over the hero video, links light */
  [data-nav].is-home:not(.is-scrolled) {
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }
  [data-nav].is-home:not(.is-scrolled) .nav-link {
    color: rgb(249 241 228); /* cream */
  }
  [data-nav].is-home:not(.is-scrolled) .nav-link:hover {
    color: #ffffff;
  }
  [data-nav].is-home:not(.is-scrolled) [data-menu-toggle] {
    color: rgb(249 241 228);
    border-color: rgba(249, 241, 228, 0.45);
  }

  /* Scrolled state: solid cream + blur + soft shadow */
  [data-nav].is-scrolled {
    background-color: rgba(249, 241, 228, 0.85);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    box-shadow: 0 8px 24px -12px rgba(26, 38, 57, 0.18);
  }
  [data-nav].is-scrolled [data-nav-border] {
    opacity: 1;
    background: rgba(26, 38, 57, 0.08);
  }

  [data-mobile-menu][data-open="true"] {
    opacity: 1;
    pointer-events: auto;
  }
  [data-mobile-menu] {
    transition: opacity 400ms cubic-bezier(0.22, 1, 0.36, 1);
  }
</style>
