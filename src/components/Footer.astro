---
import { navLinks, eventMeta, contact } from '../lib/data';

const linkItems = [
  { href: '#a-propos',    label: 'A propos' },
  { href: '#programme',   label: 'Programme' },
  { href: '#initiatives', label: 'Initiatives' },
  { href: '#gallerie',    label: 'Gallerie' },
  { href: '#contact',     label: 'Contact' }
];
---

<footer class="bg-cream">
  <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20">
    <hr class="border-0 border-t border-ink-300" />
  </div>
  <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20 pt-20 md:pt-24 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-10">
      <!-- Brand -->
      <div class="md:col-span-4" data-reveal>
        <a href="#accueil" aria-label="Échos Solidaires — accueil" class="inline-block">
          <img src="/images/logo.png" alt="أصداء — Échos Solidaires" width="256" height="256" loading="lazy" style="height: 72px; width: auto; display: block;" />
        </a>
        <p class="mt-8 text-[15px] text-[#1A2639] max-w-[42ch] leading-[1.8]">
          Échos Solidaires – <span lang="ar" dir="rtl">أصداء</span> rassemble acteurs locaux, jeunes,
          artisans et porteurs d'initiatives autour du climat, du
          patrimoine et des solidarités territoriales à Nefta.
        </p>

        <!-- Social Icons (Moved beneath paragraph as in screenshot) -->
        <ul class="mt-8 flex items-center gap-4">
          <li>
            <a
              href="https://www.facebook.com/profile.php?id=61581719152747"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook"
              class="inline-flex transition-transform duration-300 ease-editorial hover:scale-105"
            >
              <img src="/images/Footer/Facebook.svg" alt="" width="36" height="36" />
            </a>
          </li>
          <li>
            <a
              href="https://www.instagram.com/echos_solidaires/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
              class="inline-flex transition-transform duration-300 ease-editorial hover:scale-105"
            >
              <img src="/images/Footer/Insta.svg" alt="" width="36" height="36" />
            </a>
          </li>
        </ul>
      </div>

      <!-- Liens -->
      <nav class="md:col-span-3 md:col-start-6" aria-label="Plan du site" data-reveal>
        <p class="font-sans font-bold text-[18px] text-[#3F6B52]">Liens</p>
        <ul class="mt-5 flex flex-col gap-3">
          {linkItems.map((l) => (
            <li>
              <a
                href={l.href}
                class="text-[15px] text-[#1A2639] hover:text-[#C96C4B] transition-colors duration-300 ease-editorial"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Newsletter -->
      <div class="md:col-span-4" data-reveal>
        <p class="font-sans font-bold text-[18px] text-[#3F6B52]">Newsletter</p>
        <p class="mt-5 text-[15px] text-[#1A2639] leading-relaxed max-w-[32ch]">
          Restez informé de nos actualitées<br/>et prochains evenements
        </p>
        <form data-newsletter-form class="mt-6 flex gap-3 h-[50px]">
          <input
            data-newsletter-input
            type="email"
            placeholder="Enter your Email"
            class="flex-1 w-full bg-transparent border border-gray-400 rounded-lg px-4 text-[#1A2639] placeholder:text-gray-500 focus:outline-none focus:border-[#3F6B52] transition-colors disabled:opacity-50"
            required
          />
          <button
            data-newsletter-btn
            type="submit"
            class="relative inline-flex items-center justify-center bg-[#1A2639] text-white w-[130px] rounded-lg rounded-tl-none font-sans font-semibold text-[17px] hover:opacity-90 transition-all disabled:opacity-90 disabled:cursor-not-allowed overflow-hidden"
          >
            <span data-btn-text class="transition-opacity duration-300">Envoyer</span>
            <span data-btn-loader class="absolute inset-0 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
              <span class="newsletter-spinner"></span>
            </span>
            <span data-btn-success class="absolute inset-0 flex items-center justify-center gap-2 opacity-0 pointer-events-none transition-opacity duration-300 text-[#99C78C]">
              <i class="ph ph-check-circle text-[22px]"></i>
            </span>
          </button>
        </form>
      </div>
    </div>

    <hr class="mt-16 border-0 border-t border-ink-300" />

    <div class="mt-8 pt-8 flex justify-center">
      <p class="flex items-center gap-2 text-[14px] text-[#1A2639] font-medium">
        <img src="/images/Footer/c.svg" alt="©" width="22" height="22" class="inline-block" />
        <span>Login Challege 2026 - Collège Lasalle-Tunis. All rights reserved</span>
      </p>
    </div>
  </div>
</footer>

<script>
  // Simple script to handle newsletter form animation
  const forms = document.querySelectorAll('[data-newsletter-form]');
  
  forms.forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const formEl = e.currentTarget as HTMLFormElement;
      const input = formEl.querySelector('[data-newsletter-input]') as HTMLInputElement;
      const btn = formEl.querySelector('[data-newsletter-btn]') as HTMLButtonElement;
      
      if (!input.value || !input.checkValidity()) {
        input.reportValidity();
        return;
      }
      
      const text = btn.querySelector('[data-btn-text]') as HTMLElement;
      const loader = btn.querySelector('[data-btn-loader]') as HTMLElement;
      const success = btn.querySelector('[data-btn-success]') as HTMLElement;
      
      // 1. Loading State
      text.style.opacity = '0';
      loader.style.opacity = '1';
      input.disabled = true;
      btn.disabled = true;
      
      // 2. Simulate API Call (1.5 seconds)
      setTimeout(() => {
        // 3. Success State
        loader.style.opacity = '0';
        success.style.opacity = '1';
        input.value = ''; // Empty the field
        
        // 4. Reset after 2.5 seconds
        setTimeout(() => {
          success.style.opacity = '0';
          text.style.opacity = '1';
          input.disabled = false;
          btn.disabled = false;
        }, 2500);
      }, 1500);
    });
  });
</script>

<style>
  .newsletter-spinner {
    width: 20px;
    height: 20px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: n-spin 0.8s linear infinite;
  }
  @keyframes n-spin {
    to { transform: rotate(360deg); }
  }
</style>
