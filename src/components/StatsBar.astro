---
import { stats } from '../lib/data';
const iconMap: Record<string, string> = {
  users: 'ph-users-three',
  handshake: 'ph-handshake',
  heart: 'ph-heart',
  trophy: 'ph-trophy'
};
---

<section class="bg-indigo text-cream">
  <div class="max-w-content mx-auto px-6 md:px-12 lg:px-20 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-y-10 gap-x-6 text-center md:text-left">
      {stats.map((s) => (
        <div class="flex flex-col items-center md:items-start gap-3" data-reveal>
          <i class={`ph ${iconMap[s.icon] ?? 'ph-circle'} text-cream text-[24px]`} aria-hidden="true"></i>
          <div class="font-display font-medium text-cream text-[clamp(40px,6vw,56px)] leading-none">
            <span data-count={s.value}>0</span>{s.suffix}
          </div>
          <div class="text-caption uppercase tracking-[0.15em] text-cream/70">
            {s.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
